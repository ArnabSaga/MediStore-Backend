NODE_ENV=development
PORT=5000

# PostgreSQL connection string
DATABASE_URL=""

# Better Auth
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000/api/auth"
FRONTEND_URL="http://localhost:3000"

# Email sender used for verification and account emails
EMAIL_SENDER_SMTP_HOST=""
EMAIL_SENDER_SMTP_PORT="587"
EMAIL_SENDER_SMTP_USER=""
EMAIL_SENDER_SMTP_PASS=""
EMAIL_SENDER_SMTP_FROM=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudinary, required for production upload features
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
USER_PROFILE_FOLDER="medistore/profiles"
MEDICINE_FOLDER="medistore/medicines"
CATEGORY_FOLDER="medistore/categories"

# Required only when running pnpm seed:admin
ADMIN_NAME=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
